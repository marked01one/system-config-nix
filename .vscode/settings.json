{
  "Lua.diagnostics.globals": [
    "Linemode"
  ],
  "Lua.diagnostics.disable": [
    "undefined-global",
    "cast-local-type"
  ],
  "nix.enableLanguageServer": true,
  "nix.formatterPath": "alejandra",
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "alejandra"
        ],
      },
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"/home/marked01one/.nixos\").inputs.nixpkgs {}"
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"/home/marked01one/.nixos/flake.nix\").nixosConfigurations.marked01one.options"
        },
      },
    }
  },
}